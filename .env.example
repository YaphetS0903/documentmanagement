NODE_ENV=production
PORT=3000

# Use a long random value in production. Do not commit the real value.
JWT_SECRET=replace-with-a-long-random-secret

# Runtime data paths. Keep these outside the Git working tree on a server.
DATA_DIR=/data/document-platform/data
UPLOAD_DIR=/data/document-platform/uploads
TMP_DIR=/data/document-platform/tmp

# Optional: server directory that can be synchronized into the document library.
# Leave empty if the sync directory is configured later by administrators.
EXTERNAL_LIBRARY_ROOT=/data/company-documents

# Optional overrides. Normally DATA_DIR is enough.
# DB_FILE=/data/document-platform/data/db.json
# STORAGE_FILE=/data/document-platform/data/storage.json
