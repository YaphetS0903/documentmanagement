{
  "name": "document-platform",
  "version": "1.0.0-rc.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node backend/src/server.js",
    "dev:client": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "node backend/src/server.js",
    "seed": "node backend/src/seed.js",
    "test": "node backend/tests/api-smoke.mjs",
    "release:check": "npm test && npm run build && node scripts/release-check.mjs",
    "production:check": "node scripts/check-production-env.mjs",
    "migration:scan": "node scripts/migrate-filesystem.mjs scan",
    "migration:import": "node scripts/migrate-filesystem.mjs import",
    "migration:test": "node scripts/migrate-filesystem.test.mjs",
    "onlyoffice:setup": "bash scripts/setup-onlyoffice-local.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/lib-storage": "^3.1085.0",
    "@node-saml/node-saml": "^5.1.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "clamscan": "^2.4.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "element-plus": "^2.11.8",
    "express": "^4.21.2",
    "http-proxy": "^1.18.1",
    "jose": "^6.2.3",
    "ldapts": "^8.1.8",
    "lucide-vue-next": "^0.468.0",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.22.6",
    "pdf-lib": "^1.17.1",
    "pptxgenjs": "^4.0.1",
    "vite": "^6.0.7",
    "vue": "^3.5.24"
  }
}
