{
  "name": "document-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node backend/src/server.js",
    "dev:client": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "node backend/src/server.js",
    "seed": "node backend/src/seed.js",
    "test": "node backend/tests/api-smoke.mjs",
    "onlyoffice:setup": "bash scripts/setup-onlyoffice-local.sh"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "element-plus": "^2.11.8",
    "express": "^4.21.2",
    "http-proxy": "^1.18.1",
    "lucide-vue-next": "^0.468.0",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.22.6",
    "vite": "^6.0.7",
    "vue": "^3.5.24"
  }
}
